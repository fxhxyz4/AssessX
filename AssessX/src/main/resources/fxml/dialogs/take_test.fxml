<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.assessx.assessx.controller.pages.TakeTestController"
      styleClass="app-root" spacing="16" style="-fx-padding:24;">
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="titleLabel" text="Тест" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="timerLabel" text="" style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#d29922;"/>
    </HBox>
    <Label fx:id="infoLabel" text="" styleClass="card-subtitle"/>
    <ProgressIndicator fx:id="spinner" maxWidth="36" maxHeight="36"/>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:transparent;">
        <VBox fx:id="questionsBox" spacing="16"/>
    </ScrollPane>
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Label fx:id="resultLabel" text="" style="-fx-font-size:14px;-fx-text-fill:#3fb950;" HBox.hgrow="ALWAYS"/>
        <Button fx:id="submitBtn" text="Здати тест" styleClass="btn-primary"
                onAction="#onSubmit" disable="true"/>
    </HBox>
</VBox>
