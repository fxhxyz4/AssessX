<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.assessx.assessx.controller.pages.AllResultsPageController"
      styleClass="app-root" spacing="20" style="-fx-padding:0;">
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Результати груп" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="groupCombo" promptText="Виберіть групу" styleClass="combo-field"
                  onAction="#onGroupSelected"/>
    </HBox>
    <ProgressIndicator fx:id="spinner" maxWidth="36" maxHeight="36" visible="false" managed="false"/>
    <Label fx:id="emptyLabel" text="Виберіть групу для перегляду результатів" styleClass="card-subtitle"/>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:transparent;">
        <VBox fx:id="listContainer" spacing="12"/>
    </ScrollPane>
</VBox>
