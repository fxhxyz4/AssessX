<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.assessx.assessx.controller.pages.ResultsPageController"
      styleClass="app-root" spacing="20" style="-fx-padding:0;">
    <Label text="Мої результати" styleClass="page-title"/>
    <ProgressIndicator fx:id="spinner" maxWidth="36" maxHeight="36"/>
    <Label fx:id="emptyLabel" text="Результатів немає" styleClass="card-subtitle" visible="false" managed="false"/>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:transparent;">
        <VBox fx:id="listContainer" spacing="12"/>
    </ScrollPane>
</VBox>
